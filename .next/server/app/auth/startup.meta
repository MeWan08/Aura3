{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/auth/layout,_N_T_/auth/startup/layout,_N_T_/auth/startup/page,_N_T_/auth/startup"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/auth/startup/__PAGE__",
    "/auth/startup",
    "/auth",
    "/_index",
    "/_head"
  ]
}